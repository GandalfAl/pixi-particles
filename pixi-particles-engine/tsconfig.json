{
    "compilerOptions": {
        "target": "ES2020",
        "rootDir": "src",

        "module": "ESNext",
        "moduleResolution": "Bundler",

        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"]
        },

        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,

        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true
    },
    "include": ["src"]
}
